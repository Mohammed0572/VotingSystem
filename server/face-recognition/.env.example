# ── Face Authentication API Configuration ──────────────────────────────────

# ── Auth ───────────────────────────────────────────────────────────────────
# JWT secret key for the FastAPI server.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token expiry in hours (default: 2)
JWT_EXPIRY_HOURS=2

# ── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=election_admin
ADMIN_PASSWORD=your_secure_password_here

# ── Face Matching ───────────────────────────────────────────────────────────
# Face match tolerance — Euclidean distance threshold.
# Lower = stricter.  Range: 0.4 (very strict) to 0.6 (lenient).
# Default 0.5 balances accuracy and usability.
MATCH_TOLERANCE=0.5

# ── Redis (Rate Limiting Backend) ──────────────────────────────────────────
# Local dev:    redis://127.0.0.1:6379/0
# Docker:       redis://redis:6379/0
# Redis Cloud:  redis://:<password>@<host>:<port>/0
REDIS_URL=redis://127.0.0.1:6379/0
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
# Set true only when the API is served over HTTPS.
COOKIE_SECURE=false

# ── Rate Limits (requests / window) ────────────────────────────────────────
# These are enforced in main.py via @limiter.limit().
# Edit the decorator strings there to change limits.
# Documented here for visibility:
#   /verify-face  → 5/minute  per IP
#   /enroll-face  → 10/minute per IP
#   /health       → 60/minute per IP

# ── EAR Liveness Thresholds ────────────────────────────────────────────────
# EAR (Eye Aspect Ratio) for blink detection.
# Closed eye: typically < 0.21
# Open eye:   typically > 0.25
# Widen the gap if users report false rejections.
EAR_MIN_CLOSED=0.22
EAR_MIN_OPEN=0.25
