# ── Face Authentication API Configuration ──────────────────────────────────
# JWT secret key — must match the Express frontend server (root .env)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your-secret-key-here

# JWT token expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# Face match tolerance — Euclidean distance threshold.
# Lower = stricter.  Range: 0.4 (very strict) to 0.6 (lenient).
# Default 0.5 balances accuracy and usability.
MATCH_TOLERANCE=0.5
